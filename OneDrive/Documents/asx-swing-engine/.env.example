# ──────────────────────────────────────────────────────────────
# ASX Swing Engine — environment variables
# ──────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your credentials below
# 3. .env is in .gitignore — it will never be committed
# ──────────────────────────────────────────────────────────────

# Your sending email address
EMAIL_FROM=joshbendavis@hotmail.com

# App password (NOT your regular login password)
# Outlook/Hotmail: https://account.microsoft.com/security → Advanced security → App passwords
# Gmail:           https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your_app_password_here

# Who to send results to (defaults to EMAIL_FROM if left blank)
EMAIL_TO=joshbendavis@hotmail.com

# SMTP settings — Outlook/Hotmail defaults shown
# Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587

# Telegram daily summary bot
# Step 1: Message @BotFather on Telegram → /newbot → follow prompts → copy token here
# Step 2: Message @userinfobot on Telegram → it replies with your chat ID → copy here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
